        "buttons": {
          "type": "buttons",
          "settings": {
            "button_label_1": "Configure Yours",
            "button_link_1": "shopify://pages/customizer",
            "button_style_secondary_1": false
          }
        }
      },
      "block_order": [
        "heading",
        "text",
        "buttons"
      ]
    },
    "customizer": {
      "type": "customizer",
      "settings": {}
    },
    "video": {
      "type": "video",
      "settings": {
        "heading": "The Art of Precision",
        "heading_size": "h1",
        "video_url": "https://www.youtube.com/watch?v=R9Ym3x3T36U",
        "enable_video_looping": true,
        "color_scheme": "scheme-1",
        "padding_top": 60,
        "padding_bottom": 60
      }
    },
    "featured_collection": {
      "type": "featured-collection",
