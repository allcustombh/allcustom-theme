      <p class="master-subtitle">Masterpiece Custom Seiko Modifications</p>
    </div>
  </div>

  <!-- 2. PRODUCT SHOWCASE -->
  <div class="master-section">
    <h2 class="master-section-title">The Collection</h2>
    <div class="master-grid">
      <div class="master-card">
        <img src="{{ 'seiko_red.png' | file_url }}" alt="Red One Piece" onerror="this.src='https://cdn.shopify.com/s/files/1/0879/2368/7733/files/seiko_red.png'">
        <h3>The Emperor</h3>
        <p></p>
      </div>
      <div class="master-card">
        <img src="{{ 'seiko_black.png' | file_url }}" alt="Stealth Black" onerror="this.src='https://cdn.shopify.com/s/files/1/0879/2368/7733/files/seiko_black.png'">
        <h3>The Stealth Wave</h3>
        <p></p>
      </div>
      <div class="master-card">
        <img src="{{ 'seiko_orange.png' | file_url }}" alt="Orange GMT" onerror="this.src='https://cdn.shopify.com/s/files/1/0879/2368/7733/files/seiko_orange.png'">
        <h3>The Voyager</h3>
        <p>,100</p>
      </div>
    </div>
  </div>

  <!-- 3. BULLETPROOF CUSTOMIZER -->
  <div class="master-section" style="background: #121418;">
    <h2 class="master-section-title">Build Your Masterpiece</h2>
    <div class="master-customizer">
      <div class="mc-visualizer">
        <div class="mc-assembly-animation">
          <!-- GIF Simulation via CSS & Layers -->
          <div class="mc-layer" style="animation-delay: 0s; z-index: 1;"><img src="{{ 'seiko_black.png' | file_url }}" onerror="this.src='https://cdn.shopify.com/s/files/1/0879/2368/7733/files/seiko_black.png'" id="mc-render-base"></div>
        </div>
        <h3 id="mc-price-display" style="color: var(--master-gold); font-size: 2.5rem; margin-top: 2rem;"></h3>
        <p style="color: var(--master-text);">Estimated Build Time: 3-4 Weeks</p>
      </div>
      <div class="mc-controls">
        <h3 style="color: var(--master-white); font-size: 1.5rem; margin-bottom: 1rem;">1. Select Architecture</h3>
        <div class="mc-option active" onclick="updateCustomizer('https://cdn.shopify.com/s/files/1/0879/2368/7733/files/seiko_red.png', 850, this)">
          <div style="display: flex; align-items: center;">
            <img src="https://cdn.shopify.com/s/files/1/0879/2368/7733/files/seiko_red.png" alt="Red">
            <span style="color: var(--master-white); font-weight: bold;">The Emperor Base</span>
          </div>
          <span style="color: var(--master-gold);">+</span>
        </div>
        <div class="mc-option" onclick="updateCustomizer('https://cdn.shopify.com/s/files/1/0879/2368/7733/files/seiko_black.png', 950, this)">
          <div style="display: flex; align-items: center;">
            <img src="https://cdn.shopify.com/s/files/1/0879/2368/7733/files/seiko_black.png" alt="Black">
            <span style="color: var(--master-white); font-weight: bold;">Stealth Base</span>
          </div>
          <span style="color: var(--master-gold);">+</span>
        </div>
        <div class="mc-option" onclick="updateCustomizer('https://cdn.shopify.com/s/files/1/0879/2368/7733/files/seiko_orange.png', 1100, this)">
          <div style="display: flex; align-items: center;">
            <img src="https://cdn.shopify.com/s/files/1/0879/2368/7733/files/seiko_orange.png" alt="Orange">
            <span style="color: var(--master-white); font-weight: bold;">Voyager GMT Base</span>
          </div>
          <span style="color: var(--master-gold);">+,100</span>
        </div>
        
        <button class="mc-btn" onclick="alert('Configuration Locked. Redirecting to Secure Checkout...')">Finalize & Add to Cart</button>
      </div>
    </div>
  </div>

  <!-- 4. LATEST WATCH NEWS (EDITORIAL) -->
  <div class="master-section">
    <h2 class="master-section-title">The Journal</h2>
    <div class="master-grid">
      <div class="master-card" style="text-align: left;">
        <h3 style="color: var(--master-gold);">The Anatomy of the One Piece Mod</h3>
        <p style="font-size: 0.9rem; color: var(--master-text); font-weight: normal; margin-top: 1rem;">Discover the intricate details and craftsmanship that went into our latest Red Emperor design. From the custom dial to the chapter ring alignment.</p>
        <button style="background: transparent; border: 1px solid var(--master-gold); color: var(--master-gold); padding: 0.5rem 1rem; border-radius: 4px; margin-top: 1rem; cursor: pointer;">Read Article</button>
      </div>
      <div class="master-card" style="text-align: left;">
        <h3 style="color: var(--master-gold);">Ceramic vs Aluminum Bezels</h3>
        <p style="font-size: 0.9rem; color: var(--master-text); font-weight: normal; margin-top: 1rem;">Understanding the materials that protect your timepiece. Why we choose premium ceramic inserts for all Stealth Wave builds.</p>
        <button style="background: transparent; border: 1px solid var(--master-gold); color: var(--master-gold); padding: 0.5rem 1rem; border-radius: 4px; margin-top: 1rem; cursor: pointer;">Read Article</button>
      </div>
      <div class="master-card" style="text-align: left;">
        <h3 style="color: var(--master-gold);">Join the Collector's Club</h3>
        <p style="font-size: 0.9rem; color: var(--master-text); font-weight: normal; margin-top: 1rem;">Subscribe to our newsletter to receive exclusive access to 1-of-1 drops, modding tutorials, and private restocks.</p>
        <input type="email" class="mf-input" placeholder="Enter your email address" style="margin-top: 1rem; margin-bottom: 0;">
        <button class="mc-btn" style="margin-top: 0.5rem; padding: 0.5rem;">Subscribe</button>
      </div>
    </div>
  </div>

  <!-- 5. ABOUT & CONTACT FOOTER -->
  <div class="master-section" style="border-top: 1px solid rgba(197, 168, 128, 0.2); padding-bottom: 2rem;">
    <div class="master-footer-split">
      <div class="mf-half">
        <h2>The Atelier</h2>
        <p style="line-height: 1.8; opacity: 0.8;">We are masters of horological modification. Every piece is stripped down, inspected, and rebuilt using surgical-grade components. We do not just assemble watches; we engineer bespoke identities for the wrist.</p>
        <div style="margin-top: 2rem; display: flex; gap: 1rem; flex-wrap: wrap;">
          <a href="/policies/refund-policy" style="color: var(--master-gold); text-decoration: none;">Refund Policy</a>
          <a href="/policies/privacy-policy" style="color: var(--master-gold); text-decoration: none;">Privacy Policy</a>
          <a href="/policies/terms-of-service" style="color: var(--master-gold); text-decoration: none;">Terms of Service</a>
        </div>
      </div>
      <div class="mf-half">
        <h2>Concierge Inquiry</h2>
        <form onsubmit="event.preventDefault(); alert('Inquiry Sent to the Master Watchmaker.');">
          <input type="text" class="mf-input" placeholder="Full Name" required>
          <input type="email" class="mf-input" placeholder="Email Address" required>
          <textarea class="mf-input" placeholder="Describe your dream build..." rows="4" required></textarea>
          <button type="submit" class="mc-btn" style="margin-top: 0;">Submit Inquiry</button>
        </form>
      </div>
    </div>
  </div>

</div>

<script>
  // AI Canvas Particle Effect
  const canvas = document.getElementById('masterCanvas');
  const ctx = canvas.getContext('2d');
  let width, height, particles;

  function initCanvas() {
    width = canvas.width = window.innerWidth;
    height = canvas.height = window.innerHeight;
    particles = [];
    for(let i = 0; i < 100; i++) {
      particles.push({
        x: Math.random() * width,
        y: Math.random() * height,
        r: Math.random() * 2 + 1,
        dx: (Math.random() - 0.5) * 0.5,
        dy: (Math.random() - 0.5) * 0.5,
        alpha: Math.random() * 0.5 + 0.1
      });
    }
  }

  function drawParticles() {
    ctx.clearRect(0, 0, width, height);
    particles.forEach(p => {
      p.x += p.dx;
      p.y += p.dy;
      if(p.x < 0 || p.x > width) p.dx *= -1;
      if(p.y < 0 || p.y > height) p.dy *= -1;
      
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = gba(197, 168, 128, \);
      ctx.fill();
    });
    requestAnimationFrame(drawParticles);
  }

  window.addEventListener('resize', initCanvas);
  initCanvas();
  drawParticles();

  // Customizer Logic
  function updateCustomizer(imgSrc, price, el) {
    document.getElementById('mc-render-base').src = imgSrc;
    document.getElementById('mc-price-display').innerText = '$' + price;
    
    // Update active states
    document.querySelectorAll('.mc-option').forEach(opt => opt.classList.remove('active'));
    el.classList.add('active');
  }
</script>

