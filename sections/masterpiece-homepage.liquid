{% style %}
  :root {
    --master-bg: #0b0c10;
    --master-surface: #1f2833;
    --master-gold: #c5a880;
    --master-text: #c5c6c7;
    --master-white: #ffffff;
  }
  
  .masterpiece-wrapper {
    background-color: var(--master-bg);
    color: var(--master-text);
    font-family: 'Inter', sans-serif;
    width: 100%;
    overflow-x: hidden;
  }

  /* --- 1. HERO CANVAS --- */
  .master-hero {
    position: relative;
    width: 100%;
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: radial-gradient(circle at center, #1a1b20 0%, #0b0c10 100%);
  }
  .master-hero-canvas {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    z-index: 1;
    opacity: 0.6;
  }
  .master-hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .master-logo {
    width: 250px;
    margin-bottom: 2rem;
    filter: drop-shadow(0 0 20px rgba(197, 168, 128, 0.4));
    animation: master-pulse 4s infinite alternate;
  }
  .master-title {
    font-size: 4rem;
    font-family: 'Playfair Display', serif;
    color: var(--master-gold);
    margin: 0;
    letter-spacing: 4px;
    text-transform: uppercase;
  }
  .master-subtitle {
    font-size: 1.2rem;
    letter-spacing: 2px;
    margin-top: 1rem;
    color: var(--master-text);
  }

  @keyframes master-pulse {
    0% { transform: scale(1); filter: drop-shadow(0 0 10px rgba(197, 168, 128, 0.2)); }
    100% { transform: scale(1.05); filter: drop-shadow(0 0 35px rgba(197, 168, 128, 0.7)); }
  }

  /* --- 2. PRODUCT SHOWCASE --- */
  .master-section {
    padding: 6rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
  }
  .master-section-title {
    text-align: center;
    font-size: 3rem;
    font-family: 'Playfair Display', serif;
    color: var(--master-gold);
    margin-bottom: 4rem;
  }
  .master-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 3rem;
  }
  .master-card {
    background: rgba(31, 40, 51, 0.4);
    border: 1px solid rgba(197, 168, 128, 0.1);
    border-radius: 16px;
    padding: 2rem;
    text-align: center;
    backdrop-filter: blur(10px);
    transition: all 0.4s ease;
    cursor: pointer;
  }
  .master-card:hover {
    transform: translateY(-10px) scale(1.02);
    border-color: rgba(197, 168, 128, 0.5);
    box-shadow: 0 20px 40px rgba(0,0,0,0.5);
  }
  .master-card img {
    width: 100%;
    height: 350px;
    object-fit: contain;
    margin-bottom: 2rem;
    filter: drop-shadow(0 15px 15px rgba(0,0,0,0.6));
  }
  .master-card h3 {
    color: var(--master-white);
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .master-card p {
    color: var(--master-gold);
    font-size: 1.2rem;
    font-weight: bold;
  }

  /* --- 3. BULLETPROOF CUSTOMIZER --- */
  .master-customizer {
    background: var(--master-surface);
    border-radius: 20px;
    padding: 4rem;
    display: flex;
    flex-wrap: wrap;
    gap: 4rem;
    border: 1px solid rgba(197, 168, 128, 0.2);
  }
  .mc-visualizer {
    flex: 1;
    min-width: 300px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .mc-assembly-animation {
    width: 250px;
    height: 350px;
    position: relative;
    perspective: 1000px;
  }
  .mc-layer {
    position: absolute;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: mc-float 6s infinite ease-in-out;
  }
  .mc-layer img {
    width: 100%;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 10px 10px rgba(0,0,0,0.8));
  }
  @keyframes mc-float {
    0%, 100% { transform: translateY(0) rotateX(10deg); }
    50% { transform: translateY(-20px) rotateX(0deg); }
  }
  .mc-controls {
    flex: 1;
    min-width: 300px;
  }
  .mc-option {
    background: var(--master-bg);
    border: 1px solid rgba(197, 168, 128, 0.3);
    padding: 1.5rem;
    border-radius: 12px;
    margin-bottom: 1rem;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .mc-option:hover, .mc-option.active {
    background: rgba(197, 168, 128, 0.1);
    border-color: var(--master-gold);
  }
  .mc-option img {
    width: 50px;
    height: 50px;
    object-fit: contain;
    margin-right: 1rem;
  }
  .mc-btn {
    background: var(--master-gold);
    color: var(--master-bg);
    border: none;
    padding: 1rem 2rem;
    font-size: 1.2rem;
    font-weight: bold;
    border-radius: 8px;
    cursor: pointer;
    width: 100%;
    margin-top: 2rem;
    transition: all 0.3s;
  }
  .mc-btn:hover {
    background: #e6c598;
    transform: translateY(-2px);
  }

  /* --- 4. STORY & CONTACT --- */
  .master-footer-split {
    display: flex;
    flex-wrap: wrap;
    gap: 4rem;
  }
  .mf-half {
    flex: 1;
    min-width: 300px;
  }
  .mf-half h2 {
    color: var(--master-gold);
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
  }
  .mf-input {
    width: 100%;
    background: var(--master-surface);
    border: 1px solid rgba(197, 168, 128, 0.3);
    padding: 1rem;
    color: var(--master-white);
    border-radius: 8px;
    margin-bottom: 1rem;
    font-family: 'Inter', sans-serif;
  }
{% endstyle %}

<div class="masterpiece-wrapper">
  
  <!-- 1. HERO CANVAS -->
  <div class="master-hero">
    <canvas id="masterCanvas" class="master-hero-canvas"></canvas>
    <div class="master-hero-content">
      <img src="{{ 'brand_logo_transparent.png' | file_url }}" alt="Brand Logo" class="master-logo" onerror="this.src='https://cdn.shopify.com/s/files/1/0879/2368/7733/files/brand_logo_transparent.png'">
