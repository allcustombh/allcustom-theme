<style>
  :root {
    --master-bg: {{ section.settings.bg_color }};
    --master-surface: {{ section.settings.surface_color }};
    --master-gold: {{ section.settings.accent_color }};
    --master-text: {{ section.settings.text_color }};
    --master-white: #ffffff;
  }
  
  .masterpiece-wrapper {
    background-color: var(--master-bg);
    color: var(--master-text);
    font-family: 'Inter', sans-serif;
    width: 100%;
    overflow-x: hidden;
  }

  /* --- 1. HERO CANVAS --- */
  .master-hero {
    position: relative;
    width: 100%;
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: radial-gradient(circle at center, #1a1b20 0%, #0b0c10 100%);
  }
  .master-hero-canvas {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    z-index: 1;
    opacity: 0.6;
  }
  .master-hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .master-logo {
    width: 250px;
    margin-bottom: 2rem;
    filter: drop-shadow(0 0 20px rgba(197, 168, 128, 0.4));
    animation: master-pulse 4s infinite alternate;
  }
  .master-title {
    font-size: 4rem;
    font-family: 'Playfair Display', serif;
    color: var(--master-gold);
    margin: 0;
    letter-spacing: 4px;
    text-transform: uppercase;
  }
  .master-subtitle {
    font-size: 1.2rem;
    letter-spacing: 2px;
    margin-top: 1rem;
    color: var(--master-text);
  }

  @keyframes master-pulse {
    0% { transform: scale(1); filter: drop-shadow(0 0 10px rgba(197, 168, 128, 0.2)); }
    100% { transform: scale(1.05); filter: drop-shadow(0 0 35px rgba(197, 168, 128, 0.7)); }
  }

  /* --- 2. PRODUCT SHOWCASE --- */
  .master-section {
    padding: 6rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
  }
  .master-section-title {
    text-align: center;
    font-size: 3rem;
    font-family: 'Playfair Display', serif;
    color: var(--master-gold);
    margin-bottom: 4rem;
  }
  .master-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 3rem;
  }
  .master-card {
    background: rgba(31, 40, 51, 0.4);
    border: 1px solid rgba(197, 168, 128, 0.1);
    border-radius: 16px;
    padding: 2rem;
    text-align: center;
    backdrop-filter: blur(10px);
    transition: all 0.4s ease;
    cursor: pointer;
  }
  .master-card:hover {
    transform: translateY(-10px) scale(1.02);
    border-color: rgba(197, 168, 128, 0.5);
    box-shadow: 0 20px 40px rgba(0,0,0,0.5);
  }
  .master-card img {
    width: 100%;
    height: 350px;
    object-fit: contain;
    margin-bottom: 2rem;
    filter: drop-shadow(0 15px 15px rgba(0,0,0,0.6));
  }
  .master-card h3 {
    color: var(--master-white);
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .master-card p {
    color: var(--master-gold);
    font-size: 1.2rem;
    font-weight: bold;
  }

  /* --- 3. BULLETPROOF CUSTOMIZER --- */
  .master-customizer {
    background: var(--master-surface);
    border-radius: 20px;
    padding: 4rem;
    display: flex;
    flex-wrap: wrap;
    gap: 4rem;
    border: 1px solid rgba(197, 168, 128, 0.2);
  }
  .mc-visualizer {
    flex: 1;
    min-width: 300px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .mc-assembly-animation {
    width: 250px;
    height: 350px;
    position: relative;
    perspective: 1000px;
  }
  .mc-layer {
    position: absolute;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: mc-float 6s infinite ease-in-out;
  }
  .mc-layer img {
    width: 100%;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 10px 10px rgba(0,0,0,0.8));
  }
  @keyframes mc-float {
    0%, 100% { transform: translateY(0) rotateX(10deg); }
    50% { transform: translateY(-20px) rotateX(0deg); }
  }
  .mc-controls {
    flex: 1;
    min-width: 300px;
  }
  .mc-option {
    background: var(--master-bg);
    border: 1px solid rgba(197, 168, 128, 0.3);
    padding: 1.5rem;
    border-radius: 12px;
    margin-bottom: 1rem;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .mc-option:hover, .mc-option.active {
    background: rgba(197, 168, 128, 0.1);
    border-color: var(--master-gold);
  }
  .mc-option img {
    width: 50px;
    height: 50px;
    object-fit: contain;
    margin-right: 1rem;
  }
  .mc-btn {
    background: var(--master-gold);
    color: var(--master-bg);
    border: none;
    padding: 1rem 2rem;
    font-size: 1.2rem;
    font-weight: bold;
    border-radius: 8px;
    cursor: pointer;
    width: 100%;
    margin-top: 2rem;
    transition: all 0.3s;
  }
  .mc-btn:hover {
    background: #e6c598;
    transform: translateY(-2px);
  }

  /* --- 4. STORY & CONTACT --- */
  .master-footer-split {
    display: flex;
    flex-wrap: wrap;
    gap: 4rem;
  }
  .mf-half {
    flex: 1;
    min-width: 300px;
  }
  .mf-half h2 {
    color: var(--master-gold);
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
  }
  .mf-input {
    width: 100%;
    background: var(--master-surface);
    border: 1px solid rgba(197, 168, 128, 0.3);
    padding: 1rem;
    color: var(--master-white);
    border-radius: 8px;
    margin-bottom: 1rem;
    font-family: 'Inter', sans-serif;
  }
</style>

<div class="masterpiece-wrapper">
  
  <!-- 1. HERO CANVAS -->
  <div class="master-hero">
    <canvas id="masterCanvas" class="master-hero-canvas"></canvas>
    <div class="master-hero-content">
      {%- if section.settings.hero_logo != blank -%}
        <img src="{{ section.settings.hero_logo | image_url: width: 500 }}" alt="{{ section.settings.hero_title }}" class="master-logo">
      {%- else -%}
        <img src="{{ 'brand_logo_transparent.png' | file_url }}" alt="Brand Logo" class="master-logo" onerror="this.src='https://via.placeholder.com/250x250/0b0c10/c5a880?text=LOGO'">
      {%- endif -%}
      <h1 class="master-title">{{ section.settings.hero_title }}</h1>
      <p class="master-subtitle">{{ section.settings.hero_subtitle }}</p>
    </div>
  </div>

  <!-- 2. PRODUCT SHOWCASE -->
  <div class="master-section">
    <h2 class="master-section-title">The Collection</h2>
    <div class="master-grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'product_selector' -%}
          {%- assign prod = block.settings.linked_product -%}
          {%- assign p_title = prod.title | default: 'Masterpiece Model' -%}
          {%- assign p_price = prod.price | money | default: 'Contact for Price' -%}
          
          <div class="master-card" onclick="window.location.href='{{ prod.url | default: '#' }}'">
            {%- if block.settings.custom_render != blank -%}
              <img src="{{ block.settings.custom_render | image_url: width: 600 }}" alt="{{ p_title }}">
            {%- else -%}
              <img src="{{ block.settings.fallback_image | file_url }}" alt="{{ p_title }}" onerror="this.src='https://via.placeholder.com/300x400/1f2833/c5a880?text=WATCH'">
            {%- endif -%}
            <h3>{{ p_title }}</h3>
            <p>{{ p_price }}</p>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  <!-- 3. BULLETPROOF CUSTOMIZER -->
  <div class="master-section" style="background: #121418;">
    <h2 class="master-section-title">Build Your Masterpiece</h2>
    <div class="master-customizer">
      <div class="mc-visualizer">
        <div class="mc-assembly-animation">
          <div class="mc-layer" style="animation-delay: 0s; z-index: 1;">
            {%- assign first_watch = section.blocks | where: 'type', 'product_selector' | first -%}
            {%- if first_watch.settings.custom_render != blank -%}
              <img src="{{ first_watch.settings.custom_render | image_url: width: 600 }}" id="mc-render-base">
            {%- else -%}
              <img src="{{ first_watch.settings.fallback_image | file_url }}" id="mc-render-base" onerror="this.src='https://via.placeholder.com/300x400/1f2833/c5a880?text=WATCH'">
            {%- endif -%}
          </div>
        </div>
        <h3 id="mc-price-display" style="color: var(--master-gold); font-size: 2.5rem; margin-top: 2rem;">
          {{ first_watch.settings.linked_product.price | money | default: '' }}
        </h3>
        <p style="color: var(--master-text);">{{ section.settings.customizer_subtitle }}</p>
      </div>
      <div class="mc-controls">
        <h3 style="color: var(--master-white); font-size: 1.5rem; margin-bottom: 1rem;">1. Select Architecture</h3>
        
        {%- for block in section.blocks -%}
          {%- if block.type == 'product_selector' -%}
            {%- assign prod = block.settings.linked_product -%}
            {%- assign active_class = '' -%}
            {%- if forloop.first %}{% assign active_class = 'active' %}{% endif -%}
            
            {%- if block.settings.custom_render != blank -%}
              {%- assign js_img = block.settings.custom_render | image_url: width: 600 -%}
            {%- else -%}
              {%- assign js_img = block.settings.fallback_image | file_url -%}
            {%- endif -%}
            
            <div class="mc-option {{ active_class }}" onclick="updateCustomizer('{{ js_img }}', '{{ prod.price | money | default: '' }}', '{{ prod.variants.first.id }}', this)">
              <div style="display: flex; align-items: center;">
                <img src="{{ js_img }}" alt="{{ prod.title }}" onerror="this.src='https://via.placeholder.com/50x50/1f2833/c5a880?text=MOD'">
                <span style="color: var(--master-white); font-weight: bold;">{{ prod.title | default: 'Select Product in Admin' }} Base</span>
              </div>
              <span style="color: var(--master-gold);">+{{ prod.price | money | default: '' }}</span>
            </div>
          {%- endif -%}
        {%- endfor -%}
        
        <form id="master-cart-form" action="/cart/add" method="post" enctype="multipart/form-data">
          {%- assign first_id = section.blocks | where: 'type', 'product_selector' | first -%}
          <input type="hidden" name="id" id="mc-active-variant" value="{{ first_id.settings.linked_product.variants.first.id }}">
          <input type="hidden" name="quantity" value="1">
          <button type="button" class="mc-btn" onclick="submitMasterCart()">Finalize & Add to Cart</button>
        </form>
      </div>
    </div>
  </div>

  <!-- 4. LATEST WATCH NEWS (EDITORIAL) -->
  <div class="master-section">
    <h2 class="master-section-title">{{ section.settings.blog_title }}</h2>
    <div class="master-grid">
      {%- if section.settings.blog != blank and section.settings.blog.articles_count > 0 -%}
        {%- for article in section.settings.blog.articles limit: 2 -%}
          <div class="master-card" style="text-align: left;">
            <h3 style="color: var(--master-gold);">{{ article.title }}</h3>
            <p style="font-size: 0.9rem; color: var(--master-text); font-weight: normal; margin-top: 1rem;">{{ article.excerpt_or_content | strip_html | truncatewords: 20 }}</p>
            <a href="{{ article.url }}" style="display: inline-block; background: transparent; border: 1px solid var(--master-gold); color: var(--master-gold); padding: 0.5rem 1rem; border-radius: 4px; margin-top: 1rem; text-decoration: none;">Read Article</a>
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="master-card" style="text-align: left;">
          <h3 style="color: var(--master-gold);">The Anatomy of the One Piece Mod</h3>
          <p style="font-size: 0.9rem; color: var(--master-text); font-weight: normal; margin-top: 1rem;">Discover the intricate details and craftsmanship that went into our latest Red Emperor design.</p>
          <button style="background: transparent; border: 1px solid var(--master-gold); color: var(--master-gold); padding: 0.5rem 1rem; border-radius: 4px; margin-top: 1rem; cursor: pointer;">Read Article</button>
        </div>
        <div class="master-card" style="text-align: left;">
          <h3 style="color: var(--master-gold);">Ceramic vs Aluminum Bezels</h3>
          <p style="font-size: 0.9rem; color: var(--master-text); font-weight: normal; margin-top: 1rem;">Understanding the materials that protect your timepiece. Why we choose premium ceramic inserts.</p>
          <button style="background: transparent; border: 1px solid var(--master-gold); color: var(--master-gold); padding: 0.5rem 1rem; border-radius: 4px; margin-top: 1rem; cursor: pointer;">Read Article</button>
        </div>
      {%- endif -%}

      <div class="master-card" style="text-align: left;">
        <h3 style="color: var(--master-gold);">Join the Collector's Club</h3>
        <p style="font-size: 0.9rem; color: var(--master-text); font-weight: normal; margin-top: 1rem;">Subscribe to receive exclusive access to 1-of-1 drops and modding tutorials.</p>
        <input type="email" class="mf-input" placeholder="Enter your email address" style="margin-top: 1rem; margin-bottom: 0;">
        <button class="mc-btn" style="margin-top: 0.5rem; padding: 0.5rem;">Subscribe</button>
      </div>
    </div>
  </div>

  <!-- 5. ABOUT & CONTACT FOOTER -->
  <div class="master-section" style="border-top: 1px solid rgba(197, 168, 128, 0.2); padding-bottom: 2rem;">
    <div class="master-footer-split">
      <div class="mf-half">
        <h2>{{ section.settings.about_title }}</h2>
        <div style="line-height: 1.8; opacity: 0.8;">
          {{ section.settings.about_text }}
        </div>
        <div style="margin-top: 2rem; display: flex; gap: 1rem; flex-wrap: wrap;">
          {%- if section.settings.footer_menu != blank -%}
            {%- for link in section.settings.footer_menu.links -%}
              <a href="{{ link.url }}" style="color: var(--master-gold); text-decoration: none;">{{ link.title }}</a>
            {%- endfor -%}
          {%- else -%}
            <a href="/policies/refund-policy" style="color: var(--master-gold); text-decoration: none;">Refund Policy</a>
            <a href="/policies/privacy-policy" style="color: var(--master-gold); text-decoration: none;">Privacy Policy</a>
            <a href="/policies/terms-of-service" style="color: var(--master-gold); text-decoration: none;">Terms of Service</a>
          {%- endif -%}
        </div>
      </div>
      <div class="mf-half">
        <h2>Concierge Inquiry</h2>
        <form onsubmit="event.preventDefault(); alert('Inquiry Sent to the Master Watchmaker.');">
          <input type="text" class="mf-input" placeholder="Full Name" required>
          <input type="email" class="mf-input" placeholder="Email Address" required>
          <textarea class="mf-input" placeholder="Describe your dream build..." rows="4" required></textarea>
          <button type="submit" class="mc-btn" style="margin-top: 0;">Submit Inquiry</button>
        </form>
      </div>
    </div>
  </div>

</div>

<script>
  const canvas = document.getElementById('masterCanvas');
  const ctx = canvas.getContext('2d');
  let width, height, particles;

  function initCanvas() {
    width = canvas.width = window.innerWidth;
    height = canvas.height = window.innerHeight;
    particles = [];
    for(let i = 0; i < 100; i++) {
      particles.push({
        x: Math.random() * width,
        y: Math.random() * height,
        r: Math.random() * 2 + 1,
        dx: (Math.random() - 0.5) * 0.5,
        dy: (Math.random() - 0.5) * 0.5,
        alpha: Math.random() * 0.5 + 0.1
      });
    }
  }

  function drawParticles() {
    ctx.clearRect(0, 0, width, height);
    particles.forEach(p => {
      p.x += p.dx;
      p.y += p.dy;
      if(p.x < 0 || p.x > width) p.dx *= -1;
      if(p.y < 0 || p.y > height) p.dy *= -1;
      
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = "rgba(197, 168, 128, " + p.alpha + ")";
      ctx.fill();
    });
    requestAnimationFrame(drawParticles);
  }

  window.addEventListener('resize', initCanvas);
  initCanvas();
  drawParticles();

  function updateCustomizer(imgSrc, price, variantId, el) {
    document.getElementById('mc-render-base').src = imgSrc;
    document.getElementById('mc-price-display').innerText = price;
    
    // Update Add to Cart Form
    if (variantId) {
      document.getElementById('mc-active-variant').value = variantId;
    }
    
    document.querySelectorAll('.mc-option').forEach(opt => opt.classList.remove('active'));
    el.classList.add('active');
  }
  
  function submitMasterCart() {
    let variantId = document.getElementById('mc-active-variant').value;
    if(!variantId || variantId === '') {
      alert("Please select a valid product block from the Shopify Admin first.");
      return;
    }
    
    // Shopify Add to Cart AJAX POST
    let formData = {
     'items': [{
      'id': variantId,
      'quantity': 1
      }]
    };
    
    fetch(window.Shopify.routes.root + 'cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(formData)
    })
    .then(response => {
      if(response.ok) {
        alert("Masterpiece Added to Cart! Redirecting...");
        window.location.href = "/cart";
      } else {
        alert("Error adding product to cart. Please ensure product has inventory.");
      }
    })
    .catch((error) => {
      console.error('Error:', error);
      window.location.href = "/cart"; // Fallback
    });
  }
</script>

