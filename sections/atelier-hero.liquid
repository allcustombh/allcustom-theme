{%- comment -%}
  ╔══════════════════════════════════════════════════════════════╗
  ║  ATELIER DE HOROLOGY — Hero Section                        ║
  ║  Full-screen immersive landing with particle canvas,       ║
  ║  floating watch imagery, and luxury animations.            ║
  ║  Dawn v15.4.1 compatible                                   ║
  ╚══════════════════════════════════════════════════════════════╝
{%- endcomment -%}

{%- liquid
  assign bg_color = section.settings.bg_color | default: '#0b0c10'
  assign accent_color = section.settings.accent_color | default: '#c5a880'
  assign particle_count = section.settings.particle_count | default: 80

  # Extract RGB values from accent hex for rgba() usage
  assign accent_hex = accent_color | remove: '#'
  assign r1 = accent_hex | slice: 0, 2
  assign g1 = accent_hex | slice: 2, 2
  assign b1 = accent_hex | slice: 4, 2
-%}

<style>
  /* ══════════════════════════════════════════════════
     ATELIER HERO — Custom Properties
     ══════════════════════════════════════════════════ */
  .atelier-hero-section {
    --ah-bg: {{ bg_color }};
    --ah-accent: {{ accent_color }};
    --ah-accent-rgb: {{ r1 | hex_to_decimal | default: '197' }}, {{ g1 | hex_to_decimal | default: '168' }}, {{ b1 | hex_to_decimal | default: '128' }};
    --ah-surface: var(--atelier-surface, #1a1a1c);
    --ah-white: #f0ece4;
    --ah-text-muted: #9a9a9e;
    --ah-font-heading: 'Playfair Display', 'Georgia', serif;
    --ah-font-body: 'Inter', -apple-system, sans-serif;
  }

  /* ══════════════════════════════════════════════════
     ATELIER HERO — Container
     ══════════════════════════════════════════════════ */
  .atelier-hero-section {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 600px;
    max-height: 1200px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: var(--ah-bg);
    font-family: var(--ah-font-body);
    color: var(--ah-white);
  }

  /* Radial gradient overlay */
  .atelier-hero__gradient {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 30% 50%, rgba(var(--ah-accent-rgb), 0.04) 0%, transparent 70%),
      radial-gradient(ellipse 60% 80% at 70% 60%, rgba(var(--ah-accent-rgb), 0.03) 0%, transparent 70%),
      radial-gradient(circle at 50% 50%, rgba(26, 26, 28, 0.6) 0%, var(--ah-bg) 100%);
    z-index: 1;
    pointer-events: none;
  }

  /* Optional background image */
  .atelier-hero__bg-image {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .atelier-hero__bg-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.15;
    filter: saturate(0.3) contrast(1.1);
  }

  /* ══════════════════════════════════════════════════
     ATELIER HERO — Particle Canvas
     ══════════════════════════════════════════════════ */
  .atelier-hero__canvas {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    opacity: 0.7;
  }

  /* ══════════════════════════════════════════════════
     ATELIER HERO — Content Layout
     ══════════════════════════════════════════════════ */
  .atelier-hero__inner {
    position: relative;
    z-index: 5;
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 3rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
    min-height: 0;
  }

  /* ── Left: Text Content ── */
  .atelier-hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  /* Logo */
  .atelier-hero__logo-wrap {
    margin-bottom: 2rem;
    opacity: 0;
    animation: ah-fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
  }
  .atelier-hero__logo {
    width: 140px;
    height: auto;
    filter: drop-shadow(0 0 20px rgba(var(--ah-accent-rgb), 0.3));
    animation: ah-logoPulse 5s ease-in-out infinite;
  }

  /* Heading */
  .atelier-hero__title {
    font-family: var(--ah-font-heading);
    font-size: clamp(2.4rem, 5vw, 4.5rem);
    font-weight: 700;
    color: var(--ah-accent);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    line-height: 1.1;
    margin: 0 0 1.25rem 0;
    opacity: 0;
    animation: ah-fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
  }

  /* Decorative rule under title */
  .atelier-hero__rule {
    width: 80px;
    height: 1px;
    background: linear-gradient(90deg, var(--ah-accent), transparent);
    margin-bottom: 1.25rem;
    opacity: 0;
    animation: ah-fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) 0.55s forwards;
  }

  /* Subtitle */
  .atelier-hero__subtitle {
    font-family: var(--ah-font-body);
    font-size: clamp(0.85rem, 1.5vw, 1.15rem);
    font-weight: 300;
    color: var(--ah-text-muted);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    margin: 0 0 2.5rem 0;
    opacity: 0;
    animation: ah-fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) 0.65s forwards;
  }

  /* CTA Buttons */
  .atelier-hero__ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: ah-fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) 0.85s forwards;
  }

  .atelier-hero__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2.25rem;
    font-family: var(--ah-font-body);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    position: relative;
    overflow: hidden;
  }

  /* Primary CTA */
  .atelier-hero__btn--primary {
    background: var(--ah-accent);
    color: var(--ah-bg);
    border: 1px solid var(--ah-accent);
    box-shadow: 0 4px 24px rgba(var(--ah-accent-rgb), 0.25);
  }
  .atelier-hero__btn--primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.2), transparent);
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .atelier-hero__btn--primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 32px rgba(var(--ah-accent-rgb), 0.4);
  }
  .atelier-hero__btn--primary:hover::before {
    opacity: 1;
  }

  /* Secondary CTA */
  .atelier-hero__btn--secondary {
    background: transparent;
    color: var(--ah-accent);
    border: 1px solid rgba(var(--ah-accent-rgb), 0.4);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .atelier-hero__btn--secondary:hover {
    background: rgba(var(--ah-accent-rgb), 0.08);
    border-color: var(--ah-accent);
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(var(--ah-accent-rgb), 0.15);
  }

  /* ── Right: Watch Image ── */
  .atelier-hero__visual {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    opacity: 0;
    animation: ah-watchReveal 1.4s cubic-bezier(0.16, 1, 0.3, 1) 0.6s forwards;
  }

  .atelier-hero__watch-wrap {
    position: relative;
    width: 100%;
    max-width: 520px;
    animation: ah-levitate 6s ease-in-out infinite;
  }

  .atelier-hero__watch-img {
    width: 100%;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0 30px 60px rgba(0, 0, 0, 0.6))
            drop-shadow(0 0 80px rgba(var(--ah-accent-rgb), 0.15));
    position: relative;
    z-index: 2;
  }

  /* Gold glow ring behind the watch */
  .atelier-hero__watch-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 75%;
    height: 75%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(var(--ah-accent-rgb), 0.08) 0%, transparent 70%);
    filter: blur(40px);
    z-index: 1;
    animation: ah-glowPulse 4s ease-in-out infinite;
  }

  /* ══════════════════════════════════════════════════
     ATELIER HERO — Scroll Indicator
     ══════════════════════════════════════════════════ */
  .atelier-hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    animation: ah-fadeIn 1s ease 1.8s forwards;
    cursor: pointer;
  }
  .atelier-hero__scroll-text {
    font-family: var(--ah-font-body);
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--ah-text-muted);
  }
  .atelier-hero__scroll-arrow {
    width: 20px;
    height: 20px;
    border-right: 1.5px solid rgba(var(--ah-accent-rgb), 0.6);
    border-bottom: 1.5px solid rgba(var(--ah-accent-rgb), 0.6);
    transform: rotate(45deg);
    animation: ah-scrollBounce 2s ease-in-out infinite;
  }

  /* ══════════════════════════════════════════════════
     ATELIER HERO — Glassmorphism Overlay (vignette)
     ══════════════════════════════════════════════════ */
  .atelier-hero__vignette {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(11, 12, 16, 0.4) 0%, transparent 20%),
      linear-gradient(0deg, rgba(11, 12, 16, 0.8) 0%, transparent 15%),
      linear-gradient(90deg, rgba(11, 12, 16, 0.3) 0%, transparent 10%),
      linear-gradient(270deg, rgba(11, 12, 16, 0.3) 0%, transparent 10%);
  }

  /* ══════════════════════════════════════════════════
     KEYFRAMES
     ══════════════════════════════════════════════════ */
  @keyframes ah-fadeInUp {
    0% {
      opacity: 0;
      transform: translateY(40px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes ah-fadeIn {
    0% { opacity: 0; }
    100% { opacity: 1; }
  }

  @keyframes ah-watchReveal {
    0% {
      opacity: 0;
      transform: scale(0.85) translateY(30px);
    }
    100% {
      opacity: 1;
      transform: scale(1) translateY(0);
    }
  }

  @keyframes ah-levitate {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-18px);
    }
  }

  @keyframes ah-logoPulse {
    0%, 100% {
      filter: drop-shadow(0 0 15px rgba(var(--ah-accent-rgb), 0.25));
      transform: scale(1);
    }
    50% {
      filter: drop-shadow(0 0 35px rgba(var(--ah-accent-rgb), 0.55));
      transform: scale(1.03);
    }
  }

  @keyframes ah-glowPulse {
    0%, 100% {
      opacity: 0.6;
      transform: translate(-50%, -50%) scale(1);
    }
    50% {
      opacity: 1;
      transform: translate(-50%, -50%) scale(1.15);
    }
  }

  @keyframes ah-scrollBounce {
    0%, 100% {
      transform: rotate(45deg) translateY(0);
      opacity: 0.6;
    }
    50% {
      transform: rotate(45deg) translateY(6px);
      opacity: 1;
    }
  }

  @keyframes ah-particlePulse {
    0%, 100% {
      opacity: 0.3;
      transform: scale(1);
    }
    50% {
      opacity: 0.8;
      transform: scale(1.5);
    }
  }

  /* ══════════════════════════════════════════════════
     RESPONSIVE — Tablet (max-width: 989px)
     ══════════════════════════════════════════════════ */
  @media screen and (max-width: 989px) {
    .atelier-hero__inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2.5rem;
      padding: 0 2rem;
    }

    .atelier-hero__content {
      align-items: center;
      order: 1;
    }

    .atelier-hero__visual {
      order: 2;
    }

    .atelier-hero__rule {
      margin-left: auto;
      margin-right: auto;
    }

    .atelier-hero__watch-wrap {
      max-width: 360px;
    }

    .atelier-hero__ctas {
      justify-content: center;
    }

    .atelier-hero-section {
      height: auto;
      min-height: 100vh;
      padding: 2rem 0 2rem;
    }
  }

  /* ══════════════════════════════════════════════════
     RESPONSIVE — Mobile (max-width: 749px)
     ══════════════════════════════════════════════════ */
  @media screen and (max-width: 749px) {
    .atelier-hero-section {
      min-height: 100svh;
      padding: 1rem 0 1.5rem;
    }

    .atelier-hero__inner {
      padding: 0 1.25rem;
      gap: 2rem;
    }

    .atelier-hero__logo {
      width: 90px;
    }

    .atelier-hero__logo-wrap {
      margin-bottom: 1.25rem;
    }

    .atelier-hero__title {
      font-size: clamp(1.8rem, 8vw, 2.8rem);
      letter-spacing: 0.1em;
      margin-bottom: 0.75rem;
    }

    .atelier-hero__subtitle {
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      margin-bottom: 1.75rem;
    }

    .atelier-hero__ctas {
      flex-direction: column;
      width: 100%;
      gap: 0.75rem;
    }

    .atelier-hero__btn {
      width: 100%;
      padding: 0.9rem 1.5rem;
      font-size: 0.8rem;
    }

    .atelier-hero__watch-wrap {
      max-width: 280px;
    }

    .atelier-hero__scroll {
      bottom: 1rem;
    }

    .atelier-hero__scroll-text {
      font-size: 0.6rem;
    }
  }

  /* ══════════════════════════════════════════════════
     REDUCED MOTION
     ══════════════════════════════════════════════════ */
  @media (prefers-reduced-motion: reduce) {
    .atelier-hero__logo,
    .atelier-hero__watch-wrap,
    .atelier-hero__watch-glow,
    .atelier-hero__scroll-arrow {
      animation: none !important;
    }
    .atelier-hero__logo-wrap,
    .atelier-hero__title,
    .atelier-hero__rule,
    .atelier-hero__subtitle,
    .atelier-hero__ctas,
    .atelier-hero__visual,
    .atelier-hero__scroll {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
    .atelier-hero__canvas {
      display: none;
    }
  }
</style>

<section
  class="atelier-hero-section"
  id="AtelierHero-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-particle-count="{{ particle_count }}"
  data-accent-color="{{ accent_color }}"
>
  {%- comment -%} Background Image (optional) {%- endcomment -%}
  {%- if section.settings.background_image != blank -%}
    <div class="atelier-hero__bg-image">
      {{
        section.settings.background_image
        | image_url: width: 2560
        | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            sizes: '100vw',
            widths: '375, 750, 1100, 1500, 1920, 2560',
            alt: section.settings.title
      }}
    </div>
  {%- endif -%}

  {%- comment -%} Gradient overlay {%- endcomment -%}
  <div class="atelier-hero__gradient" aria-hidden="true"></div>

  {%- comment -%} Particle canvas {%- endcomment -%}
  <canvas class="atelier-hero__canvas" id="atelierParticleCanvas-{{ section.id }}" aria-hidden="true"></canvas>

  {%- comment -%} Vignette {%- endcomment -%}
  <div class="atelier-hero__vignette" aria-hidden="true"></div>

  {%- comment -%} Main Content Grid {%- endcomment -%}
  <div class="atelier-hero__inner">

    {%- comment -%} ── Left Column: Text ── {%- endcomment -%}
    <div class="atelier-hero__content">

      {%- if section.settings.logo != blank -%}
        <div class="atelier-hero__logo-wrap">
          {{
            section.settings.logo
            | image_url: width: 400
            | image_tag:
                class: 'atelier-hero__logo',
                loading: 'eager',
                fetchpriority: 'high',
                widths: '100, 140, 200, 280, 400',
                sizes: '(max-width: 749px) 90px, 140px',
                alt: section.settings.title
          }}
        </div>
      {%- endif -%}

      <h1 class="atelier-hero__title">
        {{- section.settings.title | default: 'Atelier De Horology' -}}
      </h1>

      <div class="atelier-hero__rule" aria-hidden="true"></div>

      <p class="atelier-hero__subtitle">
        {{- section.settings.subtitle | default: 'Bespoke Seiko Modifications · Bahrain' -}}
      </p>

      <div class="atelier-hero__ctas">
        {%- if section.settings.cta_label_1 != blank -%}
          <a
            href="{{ section.settings.cta_link_1 | default: '#' }}"
            class="atelier-hero__btn atelier-hero__btn--primary"
          >
            {{- section.settings.cta_label_1 -}}
          </a>
        {%- endif -%}

        {%- if section.settings.cta_label_2 != blank -%}
          <a
            href="{{ section.settings.cta_link_2 | default: '#' }}"
            class="atelier-hero__btn atelier-hero__btn--secondary"
          >
            {{- section.settings.cta_label_2 -}}
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} ── Right Column: Watch Image ── {%- endcomment -%}
    <div class="atelier-hero__visual">
      {%- if section.settings.hero_watch_image != blank -%}
        <div class="atelier-hero__watch-wrap">
          <div class="atelier-hero__watch-glow" aria-hidden="true"></div>
          {{
            section.settings.hero_watch_image
            | image_url: width: 1200
            | image_tag:
                class: 'atelier-hero__watch-img',
                loading: 'eager',
                fetchpriority: 'high',
                widths: '280, 360, 520, 720, 960, 1200',
                sizes: '(max-width: 749px) 280px, (max-width: 989px) 360px, 520px',
                alt: section.settings.title
          }}
        </div>
      {%- else -%}
        <div class="atelier-hero__watch-wrap">
          <div class="atelier-hero__watch-glow" aria-hidden="true"></div>
          {{ 'product-1' | placeholder_svg_tag: 'atelier-hero__watch-img placeholder' }}
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Scroll Indicator {%- endcomment -%}
  <div class="atelier-hero__scroll" role="button" aria-label="{{ 'general.accessibility.scroll_down' | t | default: 'Scroll down' }}" tabindex="0">
    <span class="atelier-hero__scroll-text">Discover</span>
    <div class="atelier-hero__scroll-arrow" aria-hidden="true"></div>
  </div>
</section>

<script>
  (function () {
    'use strict';

    const SECTION_ID = '{{ section.id }}';
    const section = document.getElementById('AtelierHero-' + SECTION_ID);
    if (!section) return;

    const canvas = document.getElementById('atelierParticleCanvas-' + SECTION_ID);
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    const particleCount = parseInt(section.dataset.particleCount, 10) || 80;
    const accentColor = section.dataset.accentColor || '#c5a880';

    /* ── Parse accent color to RGB ── */
    function hexToRgb(hex) {
      hex = hex.replace('#', '');
      if (hex.length === 3) {
        hex = hex[0] + hex[0] + hex[1] + hex[1] + hex[2] + hex[2];
      }
      return {
        r: parseInt(hex.substring(0, 2), 16),
        g: parseInt(hex.substring(2, 4), 16),
        b: parseInt(hex.substring(4, 6), 16)
      };
    }

    const rgb = hexToRgb(accentColor);
    let width = 0;
    let height = 0;
    let particles = [];
    let mouse = { x: -9999, y: -9999 };
    let animFrameId = null;
    let isVisible = true;

    /* ── Particle Class ── */
    class Particle {
      constructor() {
        this.reset();
      }

      reset() {
        this.x = Math.random() * width;
        this.y = Math.random() * height;
        this.baseRadius = Math.random() * 1.8 + 0.4;
        this.radius = this.baseRadius;
        this.vx = (Math.random() - 0.5) * 0.4;
        this.vy = (Math.random() - 0.5) * 0.4;
        this.baseAlpha = Math.random() * 0.4 + 0.15;
        this.alpha = this.baseAlpha;
        this.pulseSpeed = Math.random() * 0.02 + 0.005;
        this.pulseOffset = Math.random() * Math.PI * 2;
        this.life = 0;
      }

      update(time) {
        /* Gentle pulsing */
        const pulse = Math.sin(time * this.pulseSpeed + this.pulseOffset);
        this.radius = this.baseRadius + pulse * 0.5;
        this.alpha = this.baseAlpha + pulse * 0.1;

        /* Mouse parallax — subtle attraction */
        const dx = mouse.x - this.x;
        const dy = mouse.y - this.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 200) {
          const force = (200 - dist) / 200 * 0.008;
          this.vx += dx * force;
          this.vy += dy * force;
        }

        /* Apply velocity with damping */
        this.vx *= 0.99;
        this.vy *= 0.99;
        this.x += this.vx;
        this.y += this.vy;

        /* Wrap around edges */
        if (this.x < -10) this.x = width + 10;
        if (this.x > width + 10) this.x = -10;
        if (this.y < -10) this.y = height + 10;
        if (this.y > height + 10) this.y = -10;
      }

      draw() {
        ctx.beginPath();
        ctx.arc(this.x, this.y, Math.max(0.1, this.radius), 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(' + rgb.r + ',' + rgb.g + ',' + rgb.b + ',' + Math.max(0, this.alpha) + ')';
        ctx.fill();
      }
    }

    /* ── Initialize ── */
    function initCanvas() {
      const rect = section.getBoundingClientRect();
      width = canvas.width = rect.width;
      height = canvas.height = rect.height;
    }

    function initParticles() {
      particles = [];
      for (let i = 0; i < particleCount; i++) {
        particles.push(new Particle());
      }
    }

    /* ── Draw connecting lines ── */
    function drawConnections() {
      const maxDist = 120;
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);

          if (dist < maxDist) {
            const lineAlpha = (1 - dist / maxDist) * 0.15;
            ctx.beginPath();
            ctx.moveTo(particles[i].x, particles[i].y);
            ctx.lineTo(particles[j].x, particles[j].y);
            ctx.strokeStyle = 'rgba(' + rgb.r + ',' + rgb.g + ',' + rgb.b + ',' + lineAlpha + ')';
            ctx.lineWidth = 0.5;
            ctx.stroke();
          }
        }
      }
    }

    /* ── Animation Loop ── */
    function animate(time) {
      if (!isVisible) {
        animFrameId = requestAnimationFrame(animate);
        return;
      }

      ctx.clearRect(0, 0, width, height);

      for (let i = 0; i < particles.length; i++) {
        particles[i].update(time);
        particles[i].draw();
      }

      drawConnections();
      animFrameId = requestAnimationFrame(animate);
    }

    /* ── Event Listeners ── */
    function onMouseMove(e) {
      const rect = canvas.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
    }

    function onMouseLeave() {
      mouse.x = -9999;
      mouse.y = -9999;
    }

    function onTouchMove(e) {
      if (e.touches.length > 0) {
        const rect = canvas.getBoundingClientRect();
        mouse.x = e.touches[0].clientX - rect.left;
        mouse.y = e.touches[0].clientY - rect.top;
      }
    }

    function onResize() {
      initCanvas();
      /* Re-distribute particles within new bounds */
      for (let i = 0; i < particles.length; i++) {
        if (particles[i].x > width) particles[i].x = Math.random() * width;
        if (particles[i].y > height) particles[i].y = Math.random() * height;
      }
    }

    /* ── Visibility: pause when off-screen ── */
    const observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          isVisible = entry.isIntersecting;
        });
      },
      { threshold: 0.1 }
    );

    /* ── Scroll Indicator Click ── */
    const scrollIndicator = section.querySelector('.atelier-hero__scroll');
    if (scrollIndicator) {
      scrollIndicator.addEventListener('click', function () {
        const sectionHeight = section.offsetHeight;
        window.scrollTo({
          top: sectionHeight,
          behavior: 'smooth'
        });
      });
      scrollIndicator.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          scrollIndicator.click();
        }
      });
    }

    /* ── Reduced Motion Check ── */
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) return;

    /* ── Boot ── */
    initCanvas();
    initParticles();
    animate(0);
    observer.observe(section);

    section.addEventListener('mousemove', onMouseMove);
    section.addEventListener('mouseleave', onMouseLeave);
    section.addEventListener('touchmove', onTouchMove, { passive: true });
    window.addEventListener('resize', onResize);

    /* ── Cleanup on Shopify section unload ── */
    if (window.Shopify && window.Shopify.designMode) {
      document.addEventListener('shopify:section:unload', function (e) {
        if (e.detail.sectionId === SECTION_ID) {
          cancelAnimationFrame(animFrameId);
          observer.disconnect();
          section.removeEventListener('mousemove', onMouseMove);
          section.removeEventListener('mouseleave', onMouseLeave);
          section.removeEventListener('touchmove', onTouchMove);
          window.removeEventListener('resize', onResize);
        }
      });
    }
  })();
</script>

