<style>
  .atelier-process {
    --ap-bg: {{ section.settings.bg_color }};
    --ap-gold: var(--atelier-gold, #c5a880);
    --ap-surface: var(--atelier-surface, #1a1a1c);
    --ap-white: #ffffff;
    --ap-gray: #9a9a9e;
    background-color: var(--ap-bg);
    font-family: 'Inter', sans-serif;
    padding: 6rem 2rem;
    overflow: hidden;
  }

  .atelier-process__inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  /* --- Header --- */
  .atelier-process__header {
    text-align: center;
    margin-bottom: 5rem;
  }

  .atelier-process__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    color: var(--ap-gold);
    margin: 0 0 1rem;
    letter-spacing: 3px;
    text-transform: uppercase;
  }

  .atelier-process__subtitle {
    font-size: clamp(0.95rem, 1.6vw, 1.15rem);
    color: var(--ap-gray);
    letter-spacing: 1.5px;
    margin: 0;
    font-weight: 300;
  }

  /* --- Main Layout --- */
  .atelier-process__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  /* --- Image Side --- */
  .atelier-process__image-wrap {
    position: sticky;
    top: 6rem;
  }

  .atelier-process__image {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 16px;
    border: 1.5px solid rgba(197, 168, 128, 0.3);
    display: block;
    box-shadow:
      0 30px 60px rgba(0, 0, 0, 0.5),
      0 0 40px rgba(197, 168, 128, 0.06);
    transition: border-color 0.5s ease, box-shadow 0.5s ease;
  }

  .atelier-process__image:hover {
    border-color: rgba(197, 168, 128, 0.6);
    box-shadow:
      0 30px 60px rgba(0, 0, 0, 0.5),
      0 0 50px rgba(197, 168, 128, 0.12);
  }

  .atelier-process__image-placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: 16px;
    border: 1.5px solid rgba(197, 168, 128, 0.2);
    background: linear-gradient(145deg, var(--ap-surface) 0%, var(--ap-bg) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ap-gray);
    font-size: 0.85rem;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* --- Steps Side --- */
  .atelier-process__steps {
    display: flex;
    flex-direction: column;
    position: relative;
    padding-left: 2rem;
  }

  /* Gold vertical timeline line */
  .atelier-process__steps::before {
    content: '';
    position: absolute;
    left: 0;
    top: 1.2rem;
    bottom: 1.2rem;
    width: 1px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(197, 168, 128, 0.5) 10%,
      rgba(197, 168, 128, 0.5) 90%,
      transparent 100%
    );
  }

  /* --- Single Step --- */
  .atelier-process__step {
    position: relative;
    padding: 2rem 0;
    opacity: 0;
    transform: translateX(40px);
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .atelier-process__step.is-visible {
    opacity: 1;
    transform: translateX(0);
  }

  /* Staggered animation delays */
  .atelier-process__step:nth-child(1) { transition-delay: 0s; }
  .atelier-process__step:nth-child(2) { transition-delay: 0.15s; }
  .atelier-process__step:nth-child(3) { transition-delay: 0.3s; }
  .atelier-process__step:nth-child(4) { transition-delay: 0.45s; }
  .atelier-process__step:nth-child(5) { transition-delay: 0.6s; }
  .atelier-process__step:nth-child(6) { transition-delay: 0.75s; }

  /* Timeline node dot */
  .atelier-process__step::before {
    content: '';
    position: absolute;
    left: -2rem;
    top: 2.8rem;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    border: 1.5px solid var(--ap-gold);
    background: var(--ap-bg);
    transform: translateX(-4px);
    transition: background 0.4s ease, box-shadow 0.4s ease;
  }

  .atelier-process__step.is-visible::before {
    background: var(--ap-gold);
    box-shadow: 0 0 12px rgba(197, 168, 128, 0.5);
  }

  /* Step number — large outlined text */
  .atelier-process__number {
    font-family: 'Playfair Display', serif;
    font-size: clamp(3rem, 5vw, 4.5rem);
    font-weight: 700;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(197, 168, 128, 0.4);
    line-height: 1;
    margin-bottom: 0.6rem;
    letter-spacing: 2px;
    user-select: none;
    transition: -webkit-text-stroke-color 0.5s ease;
  }

  .atelier-process__step.is-visible .atelier-process__number {
    -webkit-text-stroke-color: rgba(197, 168, 128, 0.7);
  }

  /* Step title */
  .atelier-process__step-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.3rem, 2.2vw, 1.7rem);
    color: var(--ap-white);
    margin: 0 0 0.75rem;
    letter-spacing: 1px;
  }

  /* Step description */
  .atelier-process__step-desc {
    font-size: clamp(0.88rem, 1.2vw, 1rem);
    color: var(--ap-gray);
    line-height: 1.75;
    margin: 0;
    max-width: 480px;
  }

  /* --- Responsive --- */
  @media (max-width: 960px) {
    .atelier-process {
      padding: 4rem 1.5rem;
    }

    .atelier-process__header {
      margin-bottom: 3rem;
    }

    .atelier-process__layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .atelier-process__image-wrap {
      position: relative;
      top: auto;
      max-width: 560px;
      margin: 0 auto;
    }

    .atelier-process__image,
    .atelier-process__image-placeholder {
      aspect-ratio: 3 / 4;
    }

    .atelier-process__steps {
      padding-left: 1.8rem;
    }

    .atelier-process__step {
      padding: 1.5rem 0;
    }

    .atelier-process__number {
      font-size: 2.8rem;
    }
  }

  @media (max-width: 480px) {
    .atelier-process {
      padding: 3rem 1rem;
    }

    .atelier-process__header {
      margin-bottom: 2rem;
    }

    .atelier-process__steps {
      padding-left: 1.5rem;
    }

    .atelier-process__step::before {
      left: -1.5rem;
      transform: translateX(-4px);
    }

    .atelier-process__steps::before {
      left: 0;
    }

    .atelier-process__number {
      font-size: 2.4rem;
      -webkit-text-stroke-width: 1px;
    }

    .atelier-process__step-title {
      font-size: 1.2rem;
    }
  }
</style>

<div class="atelier-process" id="atelier-process-{{ section.id }}">
  <div class="atelier-process__inner">

    {%- comment -%} Section Header {%- endcomment -%}
    <div class="atelier-process__header">
      <h2 class="atelier-process__title">{{ section.settings.title }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="atelier-process__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Two-Column Layout: Image + Steps {%- endcomment -%}
    <div class="atelier-process__layout">

      {%- comment -%} Left: Process Image {%- endcomment -%}
      <div class="atelier-process__image-wrap">
        {%- if section.settings.process_image != blank -%}
          <img
            class="atelier-process__image"
            src="{{ section.settings.process_image | image_url: width: 900 }}"
            srcset="{{ section.settings.process_image | image_url: width: 500 }} 500w,
                    {{ section.settings.process_image | image_url: width: 700 }} 700w,
                    {{ section.settings.process_image | image_url: width: 900 }} 900w"
            sizes="(max-width: 960px) 90vw, 45vw"
            alt="{{ section.settings.title | escape }}"
            loading="lazy"
            width="{{ section.settings.process_image.width }}"
            height="{{ section.settings.process_image.height }}"
          >
        {%- else -%}
          <div class="atelier-process__image-placeholder">
            Select an image in the theme editor
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Right: Steps {%- endcomment -%}
      <div class="atelier-process__steps" id="atelier-steps-{{ section.id }}">
        {%- for block in section.blocks -%}
          <div class="atelier-process__step" {{ block.shopify_attributes }}>
            <div class="atelier-process__number">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</div>
            <h3 class="atelier-process__step-title">{{ block.settings.title }}</h3>
            <p class="atelier-process__step-desc">{{ block.settings.description }}</p>
          </div>
        {%- endfor -%}
      </div>

    </div>
  </div>
</div>

<script>
  (function() {
    const sectionId = '{{ section.id }}';
    const stepsContainer = document.getElementById('atelier-steps-' + sectionId);
    if (!stepsContainer) return;

    const steps = stepsContainer.querySelectorAll('.atelier-process__step');
    if (!steps.length) return;

    /* --- Intersection Observer for scroll-triggered animations --- */
    if ('IntersectionObserver' in window) {
      const observerOptions = {
        root: null,
        rootMargin: '0px 0px -60px 0px',
        threshold: 0.15
      };

      const observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);

      steps.forEach(function(step) {
        observer.observe(step);
      });
    } else {
      /* Fallback: show all steps immediately if IO is not supported */
      steps.forEach(function(step) {
        step.classList.add('is-visible');
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Atelier Process",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "process_image",
      "label": "Process Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "The Craft"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Section Subtitle",
      "default": "Every Masterpiece Follows a Sacred Process"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#0b0c10"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Process Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Step"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step Description",
          "default": "Describe this step of the process."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Atelier Process",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Consultation",
            "description": "We begin with a deep-dive into your vision. Every detail is discussed — from bezel material to lume color."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Deconstruction",
            "description": "Your base watch is surgically disassembled. Every component is inspected, catalogued, and prepared for transformation."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Assembly",
            "description": "Hand-selected components are precision-fitted by our master watchmakers. Each modification is tested to Swiss-grade tolerances."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Delivery",
            "description": "Your bespoke timepiece is pressure-tested, photographed, and delivered in a premium presentation case."
          }
        }
      ]
    }
  ]
}
{% endschema %}
