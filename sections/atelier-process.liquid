<style>
  .atelier-process {
    --ap-bg: {{ section.settings.bg_color }};
    --ap-gold: var(--atelier-gold, #c5a880);
    --ap-gold-rgb: 197, 168, 128;
    --ap-surface: var(--atelier-surface, #1a1a1c);
    --ap-white: #ffffff;
    --ap-gray: #9a9a9e;
    background-color: var(--ap-bg);
    font-family: 'Inter', sans-serif;
    padding: 5rem 2rem;
    overflow: hidden;
    position: relative;
  }

  /* Subtle background gradient */
  .atelier-process::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 60% at 30% 50%, rgba(var(--ap-gold-rgb), 0.03) 0%, transparent 70%);
    pointer-events: none;
  }

  .atelier-process__inner {
    max-width: 1400px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  /* --- Header --- */
  .atelier-process__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .atelier-process__caption {
    font-size: 0.68rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--ap-gold);
    margin: 0 0 0.8rem;
    opacity: 0;
    animation: apFadeUp 0.7s ease 0.1s forwards;
  }

  .atelier-process__title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    color: var(--ap-gold);
    margin: 0 0 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0;
    animation: apFadeUp 0.7s ease 0.25s forwards;
  }

  .atelier-process__rule {
    width: 60px;
    height: 1px;
    margin: 0 auto 1.2rem;
    background: linear-gradient(90deg, transparent, var(--ap-gold), transparent);
    opacity: 0;
    animation: apFadeUp 0.6s ease 0.35s forwards;
  }

  .atelier-process__subtitle {
    font-size: clamp(0.88rem, 1.4vw, 1.05rem);
    color: var(--ap-gray);
    letter-spacing: 0.08em;
    margin: 0;
    font-weight: 300;
    opacity: 0;
    animation: apFadeUp 0.7s ease 0.4s forwards;
  }

  @keyframes apFadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* --- Main Layout --- */
  .atelier-process__layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.5rem;
    align-items: start;
  }

  /* --- Image Side --- */
  .atelier-process__image-wrap {
    position: sticky;
    top: 6rem;
    perspective: 800px;
  }

  .atelier-process__image-container {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    border: 1.5px solid rgba(var(--ap-gold-rgb), 0.2);
    transition: border-color 0.5s ease, box-shadow 0.5s ease;
    box-shadow:
      0 30px 60px rgba(0, 0, 0, 0.5),
      0 0 40px rgba(var(--ap-gold-rgb), 0.04);
  }

  .atelier-process__image-container:hover {
    border-color: rgba(var(--ap-gold-rgb), 0.5);
    box-shadow:
      0 35px 70px rgba(0, 0, 0, 0.55),
      0 0 60px rgba(var(--ap-gold-rgb), 0.1);
  }

  /* Animated gold corner accents */
  .atelier-process__image-container::before,
  .atelier-process__image-container::after {
    content: '';
    position: absolute;
    z-index: 2;
    pointer-events: none;
    transition: opacity 0.5s ease;
  }

  .atelier-process__image-container::before {
    top: -1px;
    left: -1px;
    width: 60px;
    height: 60px;
    border-top: 2px solid var(--ap-gold);
    border-left: 2px solid var(--ap-gold);
    border-radius: 16px 0 0 0;
    opacity: 0.4;
  }

  .atelier-process__image-container::after {
    bottom: -1px;
    right: -1px;
    width: 60px;
    height: 60px;
    border-bottom: 2px solid var(--ap-gold);
    border-right: 2px solid var(--ap-gold);
    border-radius: 0 0 16px 0;
    opacity: 0.4;
  }

  .atelier-process__image-container:hover::before,
  .atelier-process__image-container:hover::after {
    opacity: 0.8;
  }

  .atelier-process__image {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
    transition: transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .atelier-process__image-container:hover .atelier-process__image {
    transform: scale(1.03);
  }

  /* Overlay gradient on image */
  .atelier-process__image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(11, 12, 16, 0.6) 100%);
    pointer-events: none;
    z-index: 1;
  }

  .atelier-process__image-placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: 16px;
    border: 1.5px solid rgba(var(--ap-gold-rgb), 0.15);
    background: linear-gradient(145deg, var(--ap-surface) 0%, var(--ap-bg) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ap-gray);
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* --- Steps Side --- */
  .atelier-process__steps {
    display: flex;
    flex-direction: column;
    position: relative;
    padding-left: 2.5rem;
  }

  /* Animated gold vertical timeline */
  .atelier-process__timeline {
    position: absolute;
    left: 0;
    top: 1rem;
    bottom: 1rem;
    width: 1px;
    background: rgba(var(--ap-gold-rgb), 0.12);
  }

  .atelier-process__timeline-fill {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 0%;
    background: linear-gradient(180deg, var(--ap-gold), rgba(var(--ap-gold-rgb), 0.3));
    transition: height 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    box-shadow: 0 0 8px rgba(var(--ap-gold-rgb), 0.3);
  }

  /* --- Single Step --- */
  .atelier-process__step {
    position: relative;
    padding: 1.8rem 0;
    opacity: 0;
    transform: translateX(30px);
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .atelier-process__step.is-visible {
    opacity: 1;
    transform: translateX(0);
  }

  /* Staggered animation delays */
  .atelier-process__step:nth-child(1) { transition-delay: 0.1s; }
  .atelier-process__step:nth-child(2) { transition-delay: 0.25s; }
  .atelier-process__step:nth-child(3) { transition-delay: 0.4s; }
  .atelier-process__step:nth-child(4) { transition-delay: 0.55s; }
  .atelier-process__step:nth-child(5) { transition-delay: 0.7s; }
  .atelier-process__step:nth-child(6) { transition-delay: 0.85s; }

  /* Timeline node dot */
  .atelier-process__dot {
    position: absolute;
    left: -2.5rem;
    top: 2.5rem;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    border: 2px solid rgba(var(--ap-gold-rgb), 0.25);
    background: var(--ap-bg);
    transform: translateX(-5px);
    transition: all 0.5s ease;
    z-index: 2;
  }

  .atelier-process__step.is-visible .atelier-process__dot {
    border-color: var(--ap-gold);
    background: var(--ap-gold);
    box-shadow: 0 0 16px rgba(var(--ap-gold-rgb), 0.5), 0 0 4px rgba(var(--ap-gold-rgb), 0.8);
  }

  /* Pulse animation on active dot */
  .atelier-process__dot::after {
    content: '';
    position: absolute;
    inset: -5px;
    border-radius: 50%;
    border: 1px solid var(--ap-gold);
    opacity: 0;
    transform: scale(0.5);
    transition: all 0.5s ease 0.3s;
  }

  .atelier-process__step.is-visible .atelier-process__dot::after {
    opacity: 0.3;
    transform: scale(1);
    animation: apDotPulse 2.5s ease-in-out infinite 1s;
  }

  @keyframes apDotPulse {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0; transform: scale(1.8); }
  }

  /* Step card container */
  .atelier-process__step-inner {
    padding: 1.5rem 1.8rem;
    border-radius: 12px;
    border: 1px solid transparent;
    background: transparent;
    transition: all 0.4s ease;
  }

  .atelier-process__step:hover .atelier-process__step-inner {
    border-color: rgba(var(--ap-gold-rgb), 0.12);
    background: rgba(var(--ap-gold-rgb), 0.02);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  /* Step number */
  .atelier-process__number {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.8rem, 4.5vw, 4rem);
    font-weight: 700;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(var(--ap-gold-rgb), 0.2);
    line-height: 1;
    margin-bottom: 0.5rem;
    letter-spacing: 2px;
    user-select: none;
    transition: all 0.6s ease;
  }

  .atelier-process__step.is-visible .atelier-process__number {
    -webkit-text-stroke-color: rgba(var(--ap-gold-rgb), 0.6);
    text-shadow: 0 0 30px rgba(var(--ap-gold-rgb), 0.08);
  }

  .atelier-process__step:hover .atelier-process__number {
    -webkit-text-stroke-color: var(--ap-gold);
    text-shadow: 0 0 40px rgba(var(--ap-gold-rgb), 0.15);
  }

  /* Step title */
  .atelier-process__step-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.2rem, 2vw, 1.55rem);
    color: var(--ap-white);
    margin: 0 0 0.6rem;
    letter-spacing: 0.04em;
    transition: color 0.3s ease;
  }

  .atelier-process__step:hover .atelier-process__step-title {
    color: var(--ap-gold);
  }

  /* Step description */
  .atelier-process__step-desc {
    font-size: clamp(0.82rem, 1.1vw, 0.92rem);
    color: var(--ap-gray);
    line-height: 1.8;
    margin: 0;
    max-width: 440px;
  }

  /* --- Responsive --- */
  @media (max-width: 960px) {
    .atelier-process {
      padding: 3.5rem 1.5rem;
    }

    .atelier-process__header {
      margin-bottom: 2.5rem;
    }

    .atelier-process__layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .atelier-process__image-wrap {
      position: relative;
      top: auto;
      max-width: 500px;
      margin: 0 auto;
    }

    .atelier-process__image {
      aspect-ratio: 3 / 4;
    }

    .atelier-process__steps {
      padding-left: 2rem;
    }

    .atelier-process__step {
      padding: 1.3rem 0;
    }

    .atelier-process__number {
      font-size: 2.5rem;
    }

    .atelier-process__dot {
      left: -2rem;
      transform: translateX(-5px);
    }
  }

  @media (max-width: 480px) {
    .atelier-process {
      padding: 2.5rem 1rem;
    }

    .atelier-process__header {
      margin-bottom: 2rem;
    }

    .atelier-process__steps {
      padding-left: 1.6rem;
    }

    .atelier-process__dot {
      left: -1.6rem;
      width: 9px;
      height: 9px;
      transform: translateX(-4px);
    }

    .atelier-process__timeline {
      left: 0;
    }

    .atelier-process__step-inner {
      padding: 1rem 1.2rem;
    }

    .atelier-process__number {
      font-size: 2.2rem;
      -webkit-text-stroke-width: 1px;
    }

    .atelier-process__step-title {
      font-size: 1.1rem;
    }

    .atelier-process__image-container::before,
    .atelier-process__image-container::after {
      width: 40px;
      height: 40px;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .atelier-process__step {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .atelier-process__caption,
    .atelier-process__title,
    .atelier-process__rule,
    .atelier-process__subtitle {
      opacity: 1 !important;
      animation: none !important;
    }
    .atelier-process__dot::after {
      animation: none !important;
    }
  }
</style>

<div class="atelier-process" id="atelier-process-{{ section.id }}">
  <div class="atelier-process__inner">

    {%- comment -%} Section Header {%- endcomment -%}
    <div class="atelier-process__header">
      <p class="atelier-process__caption">Our Process</p>
      <h2 class="atelier-process__title">{{ section.settings.title }}</h2>
      <div class="atelier-process__rule" aria-hidden="true"></div>
      {%- if section.settings.subtitle != blank -%}
        <p class="atelier-process__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Two-Column Layout: Image + Steps {%- endcomment -%}
    <div class="atelier-process__layout">

      {%- comment -%} Left: Process Image with gold corner accents {%- endcomment -%}
      <div class="atelier-process__image-wrap">
        {%- if section.settings.process_image != blank -%}
          <div class="atelier-process__image-container">
            <img
              class="atelier-process__image"
              src="{{ section.settings.process_image | image_url: width: 900 }}"
              srcset="{{ section.settings.process_image | image_url: width: 500 }} 500w,
                      {{ section.settings.process_image | image_url: width: 700 }} 700w,
                      {{ section.settings.process_image | image_url: width: 900 }} 900w"
              sizes="(max-width: 960px) 90vw, 45vw"
              alt="{{ section.settings.title | escape }}"
              loading="lazy"
              width="{{ section.settings.process_image.width }}"
              height="{{ section.settings.process_image.height }}"
            >
            <div class="atelier-process__image-overlay"></div>
          </div>
        {%- else -%}
          <div class="atelier-process__image-placeholder">
            Select an image in the theme editor
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Right: Animated Steps with fill-in timeline {%- endcomment -%}
      <div class="atelier-process__steps" id="atelier-steps-{{ section.id }}">
        <div class="atelier-process__timeline">
          <div class="atelier-process__timeline-fill" id="atelier-timeline-fill-{{ section.id }}"></div>
        </div>

        {%- for block in section.blocks -%}
          <div class="atelier-process__step" {{ block.shopify_attributes }}>
            <div class="atelier-process__dot"></div>
            <div class="atelier-process__step-inner">
              <div class="atelier-process__number">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</div>
              <h3 class="atelier-process__step-title">{{ block.settings.title }}</h3>
              <p class="atelier-process__step-desc">{{ block.settings.description }}</p>
            </div>
          </div>
        {%- endfor -%}
      </div>

    </div>
  </div>
</div>

<script>
  (function() {
    const sectionId = '{{ section.id }}';
    const stepsContainer = document.getElementById('atelier-steps-' + sectionId);
    const timelineFill = document.getElementById('atelier-timeline-fill-' + sectionId);
    if (!stepsContainer) return;

    const steps = stepsContainer.querySelectorAll('.atelier-process__step');
    if (!steps.length) return;

    let revealedCount = 0;
    const totalSteps = steps.length;

    /* --- Intersection Observer for scroll-triggered animations --- */
    if ('IntersectionObserver' in window) {
      const observerOptions = {
        root: null,
        rootMargin: '0px 0px -50px 0px',
        threshold: 0.2
      };

      const observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
            revealedCount++;

            /* Animate the timeline fill based on how many steps are revealed */
            if (timelineFill) {
              const pct = (revealedCount / totalSteps) * 100;
              timelineFill.style.height = pct + '%';
            }
          }
        });
      }, observerOptions);

      steps.forEach(function(step) {
        observer.observe(step);
      });
    } else {
      steps.forEach(function(step) {
        step.classList.add('is-visible');
      });
      if (timelineFill) timelineFill.style.height = '100%';
    }
  })();
</script>

{% schema %}
{
  "name": "Atelier Process",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "process_image",
      "label": "Process Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "The Craft"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Section Subtitle",
      "default": "Every Masterpiece Follows a Sacred Process"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#0b0c10"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Process Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step Title",
          "default": "Step"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step Description",
          "default": "Describe this step of the process."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Atelier Process",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Consultation",
            "description": "We begin with a deep-dive into your vision. Every detail is discussed — from bezel material to lume color, crystal type to hour-hand finishing."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Deconstruction",
            "description": "Your base watch is surgically disassembled. Every component is inspected, catalogued, and prepared for its transformation."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Assembly",
            "description": "Hand-selected components are precision-fitted by our master watchmakers. Each modification is tested to Swiss-grade tolerances."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Delivery",
            "description": "Your bespoke timepiece is pressure-tested, professionally photographed, and delivered in a premium presentation case."
          }
        }
      ]
    }
  ]
}
{% endschema %}
